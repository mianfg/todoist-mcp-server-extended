# Todoist API token - used by the MCP server to call Todoist API
# Get it from: https://todoist.com/app/settings/integrations → Developer
TODOIST_API_TOKEN=your_todoist_api_token_here

# MCP access token - required in Authorization header when connecting from Claude/Cursor
# Generate a random string and use it in your MCP client config
MCP_ACCESS_TOKEN=your_secret_access_token_here
